# AIPulse Environment Configuration
# Copy this file to .env and fill in your values
# This file works for both local development AND Docker deployment

# =============================================================================
# REQUIRED: Finnhub API Key
# Get your free API key at https://finnhub.io
# =============================================================================
FINNHUB_API_KEY=your_finnhub_api_key_here

# =============================================================================
# Backend Configuration
# =============================================================================
PORT=3001
CORS_ORIGIN=http://localhost:5173
CACHE_TTL_SECONDS=60

# Database Configuration
# For local dev with Docker DB services (docker-compose.dev.yml): use localhost
# For full Docker deployment: these are auto-configured in docker-compose.prod.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aipulse
REDIS_URL=redis://localhost:6379

# Data Persistence Intervals (seconds)
# Dev: Aggressive (15s/60s) to prevent data loss during frequent restarts
# Prod: Relaxed (30s/300s) for better performance
L1_TO_REDIS_INTERVAL=15
REDIS_TO_DB_INTERVAL=60
MAX_BUFFER_SIZE=10

# =============================================================================
# Rate Limit Configuration (Finnhub Free Tier: 60 calls/min)
# =============================================================================
# Max calls allowed per minute (default: 58, leaving 2 for clock skew)
# For aggressive development: set to 60 to use full limit
# For safety: set to 55 or lower
FINNHUB_MAX_CALLS_PER_MINUTE=58

# Warning threshold - log warning when this many calls used (default: 50)
FINNHUB_WARNING_THRESHOLD=50

# Auto-refresh interval in milliseconds (default: 120000 = 2 minutes)
# With 12 stocks: 120s = 30 calls/min used, leaving 30 for other operations
# For development with frequent redeploys: use 60000 (1min) for fresher data
# For production safety: use 180000 (3min) or 300000 (5min)
AUTO_REFRESH_INTERVAL_MS=120000

# Reserve this many calls for user-initiated requests (historical data, etc.)
# Default: 20 calls reserved, only auto-refresh if we have buffer+stocks remaining
RATE_LIMIT_BUFFER=20

# Warm cache on startup - immediately fetch fresh data when server starts
# Useful for development with frequent redeploys (so you see fresh data immediately)
# Set to 'true' to enable (uses ~12 API calls on startup)
WARM_CACHE_ON_STARTUP=false

# Stale data threshold (seconds) - refresh if data is older than this
# Default: 300 (5min) for production
# For development with frequent redeploys: 60 (1min) or 30 (30s)
STALE_DATA_THRESHOLD_SECONDS=300

# =============================================================================
# Redeployment / Startup Optimization
# =============================================================================
# WebSocket subscription batch delay (milliseconds)
# When clients subscribe on startup, wait this long to batch API calls
# Default: 500ms (good for 12 stocks). Increase to 1000-2000ms for more stocks
# This prevents API spikes on frequent redeployments
WS_BATCH_DELAY_MS=500

# =============================================================================
# Frontend Configuration (Vite)
# =============================================================================
# API URL - leave empty for same-origin (proxy in dev)
VITE_API_URL=

# WebSocket URL
VITE_WS_URL=ws://localhost:3001/ws
