# AIPulse Environment Configuration
# Copy this file to .env and fill in your values
# This file works for both local development AND Docker deployment

# =============================================================================
# REQUIRED: Finnhub API Key
# Get your free API key at https://finnhub.io
# =============================================================================
FINNHUB_API_KEY=your_finnhub_api_key_here

# =============================================================================
# Backend Configuration
# =============================================================================
PORT=3001
# CORS origin - update this to your production domain when deploying!
# For local dev: http://localhost:5173
# For production: https://your-domain.com
CORS_ORIGIN=http://localhost:5173
CACHE_TTL_SECONDS=60

# Database Configuration
# For local dev with Docker DB services (docker-compose.dev.yml): use localhost
# For full Docker deployment: these are auto-configured in docker-compose.prod.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aipulse
REDIS_URL=redis://localhost:6379

# Data Persistence Intervals (seconds)
# Dev: Aggressive (15s/60s) to prevent data loss during frequent restarts
# Prod: Relaxed (30s/300s) for better performance
L1_TO_REDIS_INTERVAL=15
REDIS_TO_DB_INTERVAL=60
MAX_BUFFER_SIZE=10

# =============================================================================
# Rate Limit Configuration (Finnhub Free Tier: 60 calls/min)
# =============================================================================
# Max calls allowed per minute (default: 50, leaving 10 for safety/burst)
# For aggressive usage: set to 58-60
# For safety with historical fetching: set to 45-50
FINNHUB_MAX_CALLS_PER_MINUTE=50

# Warning threshold - log warning when this many calls used (default: 50)
FINNHUB_WARNING_THRESHOLD=50

# Auto-refresh interval in milliseconds (default: 120000 = 2 minutes)
# With 12 stocks: 120s = 30 calls/min used, leaving 20 for other operations
# For development: use 180000 (3min) to conserve rate limit
# For production: use 120000 (2min) or 60000 (1min) for fresher data
AUTO_REFRESH_INTERVAL_MS=180000

# Reserve this many calls for user-initiated requests (historical data, etc.)
# Default: 20 calls reserved, only auto-refresh if we have buffer+stocks remaining
RATE_LIMIT_BUFFER=20

# Warm cache on startup - immediately fetch fresh data when server starts
# ⚠️ WARNING: Uses ~12 API calls immediately! 
# 
# For LOCAL DEVELOPMENT (frequent restarts): KEEP AS 'false'
# - Relies on Redis cache from previous run (survives restarts)
# - Saves API calls on every code change/restart
# 
# For PRODUCTION DOCKER DEPLOYMENTS: Set to 'true'
# - Docker containers start fresh with no cache
# - Users see data immediately instead of waiting for auto-refresh
WARM_CACHE_ON_STARTUP=false

# Stale data threshold (seconds) - refresh if data is older than this
# Default: 300 (5min) for production
# For development with frequent redeploys: 60 (1min) or 30 (30s)
STALE_DATA_THRESHOLD_SECONDS=300

# =============================================================================
# Redeployment / Startup Optimization
# =============================================================================
# WebSocket subscription batch delay (milliseconds)
# When clients subscribe on startup, wait this long to batch API calls
# Default: 500ms (good for 12 stocks). Increase to 1000-2000ms for more stocks
# This prevents API spikes on frequent redeployments
WS_BATCH_DELAY_MS=500

# =============================================================================
# Frontend Configuration (Vite)
# =============================================================================
# API URL - leave empty for same-origin (proxy in dev)
VITE_API_URL=

# WebSocket URL (optional - auto-detected if not set)
# The app automatically uses wss:// (HTTPS) or ws:// (HTTP) with the current host
# Only set this if you need a custom WebSocket endpoint
# VITE_WS_URL=wss://aipulse.falkenby.com/ws

# =============================================================================
# 🎯 RECOMMENDED CONFIGURATIONS
# =============================================================================

# --- LOCAL DEVELOPMENT (frequent backend restarts, conserve rate limit) ---
# FINNHUB_MAX_CALLS_PER_MINUTE=50       # Conservative to prevent exhaustion
# AUTO_REFRESH_INTERVAL_MS=180000       # 3min - save calls for development
# STALE_DATA_THRESHOLD_SECONDS=300      # 5min - don't refresh too aggressively
# RATE_LIMIT_BUFFER=15                  # Reserve for occasional historical fetch
# WARM_CACHE_ON_STARTUP=false           # ❌ NEVER warm on local dev!
# WS_BATCH_DELAY_MS=500
# 
# API Usage: ~12 calls/min (12 stocks / 3min refresh)
# Historical data fetching disabled when rate limit < 20 calls
# Redis persists between restarts, so you get cached data immediately.

# --- PRODUCTION DOCKER (deployed, infrequent restarts) ---
# FINNHUB_MAX_CALLS_PER_MINUTE=55       # Slightly more aggressive
# AUTO_REFRESH_INTERVAL_MS=120000     # 2min - balanced
# STALE_DATA_THRESHOLD_SECONDS=300    # 5min - standard
# RATE_LIMIT_BUFFER=20                # Reserve for user requests
# WARM_CACHE_ON_STARTUP=true          # ✅ Warm cache for fresh containers
# WS_BATCH_DELAY_MS=500
#
# API Usage: ~30 calls/min + 12 on deploy (one-time)
# Docker containers have no cache, so warming is essential.
